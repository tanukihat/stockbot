# ── Required ────────────────────────────────────────────────────────────────

# Alpaca — paper trading by default; swap URL for live trading
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# Anthropic — used for signal analysis (Claude Haiku)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Telegram — bot token from @BotFather, chat ID from getUpdates
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Optional ─────────────────────────────────────────────────────────────────

# Finnhub — free tier available at finnhub.io
FINNHUB_API_KEY=your-finnhub-api-key

# OpenRouter — alternative model provider (free tier models available)
OPENROUTER_API_KEY=your-openrouter-api-key

# Status page — only needed if self-hosting the dashboard (see status/README.md)
# Set STATUS_PAGE_URL to your server's event endpoint
STATUS_PAGE_URL=https://your-domain.com/stockbot/api/event
STATUS_PAGE_SECRET=generate-a-random-secret-here
