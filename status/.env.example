# Alpaca credentials (same as your stockbot .env)
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key

# Secret shared between the status page and your stockbot instance
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
STATUS_PAGE_SECRET=generate-a-random-secret-here
